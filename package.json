{
  "name": "binary-clock",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "prepare": "is-ci || husky",
    "test:e2e": "start-server-and-test preview http://localhost:4173 'cypress run --e2e'",
    "test:e2e:dev": "start-server-and-test 'vite dev --port 4173' http://localhost:4173 'cypress open --e2e'",
    "test:unit": "cypress run --component",
    "test:unit:dev": "cypress open --component",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "prettier --write --experimental-cli src/",
    "lint-staged": "lint-staged"
  },
  "dependencies": {
    "@fontsource-variable/orbitron": "^5.2.8",
    "@fontsource-variable/roboto-mono": "^5.2.8",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/vue-fontawesome": "^3.2.0",
    "@tailwindcss/vite": "^4.2.4",
    "dayjs": "^1.11.20",
    "tailwindcss": "^4.2.4",
    "vue": "^3.5.33"
  },
  "devDependencies": {
    "@prettier/plugin-xml": "^3.4.2",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.2",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.1",
    "cypress": "^15.14.2",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-cypress": "^6.4.0",
    "eslint-plugin-oxlint": "^1.62.0",
    "eslint-plugin-vue": "^10.9.0",
    "husky": "^9.1.7",
    "is-ci": "^4.1.0",
    "jiti": "^2.6.1",
    "lint-staged": "^16.4.0",
    "npm-run-all2": "^8.0.4",
    "oxlint": "^1.62.0",
    "prettier": "^3.8.3",
    "start-server-and-test": "^3.0.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vue-tsc": "^3.2.7"
  },
  "engines": {
    "node": ">=22.11.0"
  },
  "packageManager": "pnpm@11.0.4+sha512.0a397165007a014ed52919a61e5f46c48b9bca88404c303ecaecc63f62def563898d3c6b8a5d5ea5811eb398cfe03ab05da1a5ce963f126d5ead4c02f93b83c3"
}
